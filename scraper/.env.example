# PostgreSQL connection string
# Supabase: Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://user:password@host:5432/fragrance_tracker

# Redis (BullMQ job queue)
# Upstash: free managed Redis — copy the host/port/password from their dashboard
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email alerts via Resend (https://resend.com — free tier: 3k emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=alerts@yourdomain.com

# App base URL (used in email links)
APP_URL=http://localhost:3000

# Worker concurrency — how many retailers scraped in parallel
# Keep at 2-3 to avoid IP bans; increase only with proxies
WORKER_CONCURRENCY=3

# Logging: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info
NODE_ENV=development
